{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Svelte Drawer",
  "theme": "palm",
  "colors": {
    "primary": "#FF3E00",
    "light": "#FF6B35",
    "dark": "#CC3100"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/AbhiVarde/svelte-drawer"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/AbhiVarde/svelte-drawer"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "installation",
              "quickstart"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/directions",
              "guides/variants",
              "guides/snap-points",
              "guides/portal",
              "guides/keyboard-accessibility",
              "guides/persistent-state",
              "guides/styling"
            ]
          },
          {
            "group": "Examples",
            "pages": [
              "examples/basic-drawer",
              "examples/side-drawer",
              "examples/with-snap-points",
              "examples/custom-variants",
              "examples/nested-drawers"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Components",
            "pages": [
              "api/drawer",
              "api/drawer-content",
              "api/drawer-overlay",
              "api/drawer-handle",
              "api/drawer-variants",
              "api/drawer-portal",
              "api/drawer-header",
              "api/drawer-footer"
            ]
          },
          {
            "group": "Utilities",
            "pages": [
              "api/storage-utilities"
            ]
          },
          {
            "group": "Types",
            "pages": [
              "api/typescript-types"
            ]
          }
        ]
      }
    ]
  }
}
